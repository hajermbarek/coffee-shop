<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Cozy Café{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

        <!-- Custom CSS -->
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        <link rel="stylesheet" href="{{ asset('css/books.css') }}">
        <link rel="stylesheet" href="{{ asset('css/games.css') }}">
        <link rel="stylesheet" href="{{ asset('css/seatingbooks.css') }}">
        <link rel="stylesheet" href="{{ asset('css/seating_games.css') }}">
        <link rel="stylesheet" href="{{ asset('css/Menu_Style.css') }}">
        <link rel="stylesheet" href="{{ asset('css/menustyle.css') }}">
        <link rel="stylesheet" href="{{ asset('css/reservation.css') }}">

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        <!-- NAVBAR -->
        <nav class="navbar navbar-expand bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('app_home') }}">Cozy Café</a>
                <div class="navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('menu_main') }}"><b>Full Menu</b></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Our Story</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Events</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="site-footer">
            <div class="footer-main">
                <div class="footer-columns">
                    <div class="footer-brand">
                        <h3>COZY CAFÉ</h3>
                        <p>A warm place for great brews &amp; good moments</p>
                    </div>

                    <div class="footer-group">
                        <h4>ABOUT</h4>
                        <ul>
                            <li><a href="#">Our Story</a></li>
                            <li><a href="https://www.google.com/maps/place/INSAT" target="_blank">Location</a></li>
                            <li><a href="#">Careers</a></li>
                            <li><a href="#">Sustainability</a></li>
                        </ul>
                    </div>

                    <div class="footer-group">
                        <h4>MENU</h4>
                        <ul>
                            <li><a href="{{ path('menu_hot') }}">Hot Drinks</a></li>
                            <li><a href="{{ path('menu_cold') }}">Cold Brews</a></li>
                            <li><a href="{{ path('menu_blended') }}">Blended Drinks</a></li>
                            <li><a href="{{ path('menu_pastry') }}">Pastry</a></li>
                            <li><a href="{{ path('menu_biscuit') }}">Biscuits</a></li>
                            <li><a href="#">Gift Cards</a></li>
                        </ul>
                    </div>

                    <div class="footer-group">
                        <h4>MORE</h4>
                        <ul>
                            <li><a href="#">Contact Us</a></li>
                            <li><a href="#">FAQs</a></li>
                            <li><a href="#">Reservations</a></li>
                            <li><a href="#">Accessibility</a></li>
                        </ul>
                    </div>
                </div>

                <div class="footer-newsletter">
                    <h4>STAY UPDATED</h4>
                    <p>Join our newsletter for new brews, events, offers, and cozy café news.</p>
                    <div class="subscribe-form">
                        <input type="email" placeholder="Enter your email address">
                        <button type="button">→</button>
                    </div>
                    <div class="social-icons">
                        <a href="https://facebook.com" target="_blank" aria-label="Facebook">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22C17.5228 22 22 17.5228 22 12ZM12.8333 19.8333V12.8333H15.5L16 10H12.8333V8.33333C12.8333 7.5 13 7 14.1667 7H16V4.16667C15.8333 4.16667 14.1667 4 12.5 4C10.1667 4 8.5 5.5 8.5 8V10H5.83333V12.8333H8.5V19.8333H12.8333Z" fill="#e8d9c5"/>
                            </svg>
                        </a>
                        <a href="https://x.com" target="_blank" aria-label="X">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="#e8d9c5"/>
                            </svg>
                        </a>
                        <a href="https://instagram.com" target="_blank" aria-label="Instagram">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.332.014 7.052.072 2.578.225.225 2.581.072 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.153 4.471 2.506 6.825 6.98 6.977 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.471-.153 6.824-2.506 6.977-6.977.058-1.28.072-1.689.072-4.948 0-3.259-.014-3.668-.072-4.948-.153-4.471-2.506-6.824-6.977-6.977C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z" fill="#e8d9c5"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <p>© 2026 Cozy Café • Centre Urbain Nord, Tunis • All rights reserved</p>
                <p>
                    <a href="#">Privacy Policy</a> •
                    <a href="#">Terms of Use</a> •
                    <a href="#">Cookie Preferences</a>
                </p>
            </div>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        <script>
        document.querySelectorAll('.customize-toggle').forEach(toggle => {
            toggle.addEventListener('click', () => {
                const panel = toggle.nextElementSibling;
                const isOpen = panel.classList.contains('open');
                document.querySelectorAll('.customize-panel.open').forEach(p => {
                    if (p !== panel) p.classList.remove('open');
                });
                document.querySelectorAll('.customize-toggle.active').forEach(t => {
                    if (t !== toggle) t.classList.remove('active');
                });
                panel.classList.toggle('open', !isOpen);
                toggle.classList.toggle('active', !isOpen);
            });
        });
        </script>

        <script src="{{ asset('js/games.js') }}"></script>
        <script src="{{ asset('js/seatingbooks.js') }}"></script>
        <script src="{{ asset('js/seating_games.js') }}"></script>
    </body>
</html>