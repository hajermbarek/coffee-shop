{% extends 'base.html.twig' %}

{% block body %}
<div class="top">
    <h1>Reserve your seat!</h1>
    <h4>pick a table on the floor plan then choose time and date</h4>
</div>

<div class="container">
    <div class="dt">
        <form method="post" action="{{ path('seating_fun_select') }}" id="reservationForm">
            <input type="hidden" name="table_id" id="table_id_input" value="" />
            <input type="hidden" name="table_numero" id="table_numero_input" value="" />

            <div>
                <label for="table">Selected table:</label>
                <input type="text" id="table" readonly />
            </div>
            <div>
                <label for="date">Date:</label>
                <input type="date" id="date" name="date" min="{{ "now"|date("Y-m-d") }}" max="2026-12-31" required />
            </div>
            <div>
                <label for="time">Time:</label>
                <input type="time" id="time" name="time" min="08:30" max="23:00" required />
            </div>
            <button type="submit" class="reserve_button">Reserve table</button>
        </form>
    </div>

    <div class="floor">
        {% for table in tables %}
            <div class="table4" data-id="{{ table.idTable }}" data-numero="{{ table.numero }}" data-seats="{{ table.places }}">
                <div class="number">{{ table.numero }}</div>
            </div>
        {% endfor %}
        <div class="counter" id="counter">Counter</div>
    </div>
</div>
{% endblock %}