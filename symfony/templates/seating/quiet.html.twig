{% extends 'base.html.twig' %}

{% block body %}
<header>
    <h1>Reservation</h1>
    <p class="title">pick a table on the floor plan then choose the time and date</p>
</header>

<section>
    <div class="arrange">
        <p>Book a Table</p>
        <div class="table-surf">
            {% for table in tables %}
                <button class="table-top" data-table="{{ table.idTable }}" data-seats="{{ table.places }} seats">
                    <span class="number">{{ table.numero }}</span>
                    <span class="seats">{{ table.places }} places</span>
                </button>
            {% endfor %}
        </div>
    </div>

    <div class="select">
        <form method="post" action="{{ path('seating_quiet_select') }}" id="reservationForm">
            <input type="hidden" name="table_id" id="table_id_input" value="" />

            <div class="booking">
                <label>Selected table :</label>
                <div class="selected-box">
                    <p id="slcttable">—</p>
                </div>
            </div>

            <div class="date">
                <label for="date">Pick a day :</label>
                <input type="date" id="date" name="date" min="{{ "now"|date("Y-m-d") }}" required />
            </div>

            <div class="time">
                <label for="timeSelect">Pick a time :</label>
                <select id="timeSelect" name="time" size="5" required>
                    {% for hour in range(9, 17) %}
                        <option value="{{ "%02d:00"|format(hour) }}">{{ "%02d:00"|format(hour) }}</option>
                        <option value="{{ "%02d:30"|format(hour) }}">{{ "%02d:30"|format(hour) }}</option>
                    {% endfor %}
                </select>
            </div>

            <button type="submit" class="reserve">Reserve now</button>
        </form>
    </div>
</section>
{% endblock %}