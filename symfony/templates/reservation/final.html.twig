{% extends 'base.html.twig' %}

{% block body %}
<header>
    <h1>Cozy Café</h1>
    <p>Your daily dose of happiness</p>
</header>

<form method="post" class="reservation-form">
    <h2>Finalize Your Reservation</h2>

    <label>Prénom :</label>
    <input type="text" name="firstname" required>

    <label>Nom :</label>
    <input type="text" name="name" required>

    <label>Email :</label>
    <input type="email" name="email" required>

    <label>Téléphone :</label>
    <input type="tel" name="phone" required>

    <label>Date :</label>
    <input type="text" value="{{ date }}" readonly>

    <label>Heure :</label>
    <input type="text" value="{{ time }}" readonly>

    <label>Nombre de personnes :</label>
    <input type="number" name="people" min="1" required>

    <label>Zone :</label>
    <input type="text" value="{{ zone }}" readonly>

    <label>Table :</label>
    <input type="text" value="{{ tableId }}" readonly>

    <label>Activité :</label>
    <input type="text" value="{{ activity }}" readonly>

    <label>Allergies :</label>
    <textarea name="allergies"></textarea>

    <label>Commentaires :</label>
    <textarea name="comments"></textarea>

    <button type="submit">Confirmer la réservation</button>
</form>
{% endblock %}