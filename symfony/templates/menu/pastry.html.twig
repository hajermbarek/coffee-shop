{% extends 'base.html.twig' %}

{% block body %}
<header>
    <h1>Cozy Café</h1>
    <p>Your daily dose of happiness</p>
</header>

<section style="padding: 40px 20px; text-align: center;">
    <h2>Pastry</h2>
    <div class="menu">
        {% for item in items %}
            <div class="item {% if item.isPopular %}popular{% endif %}">
                {% if item.isPopular %}
                    <span class="badge">Popular</span>
                {% endif %}
                <img src="{{ item.imageUrl }}" alt="{{ item.name }}" class="drink-img" onerror="this.src='{{ asset('images/default-drink.png') }}'">
                <h3>{{ item.name }}</h3>
                <p>{{ item.description }}</p>
                <p class="price">{{ item.price }}</p>
                <button class="order-btn" onclick="alert('Ordering {{ item.name }}...')">Order Now</button>
            </div>
        {% else %}
            <p>No items found.</p>
        {% endfor %}
    </div>
</section>
{% endblock %}