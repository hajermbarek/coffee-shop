{% extends 'base.html.twig' %}

{% block page_scripts %}{% endblock %}

{% block body %}
<style>
.detail-page {
    max-width: 900px;
    margin: 2rem auto;
    padding: 1rem;
    font-family: 'Georgia', serif;
}
.detail-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.08);
    display: flex;
    gap: 2rem;
    padding: 2rem;
    align-items: flex-start;
}
.detail-cover {
    flex-shrink: 0;
    width: 220px;
    background: #f5f0eb;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    overflow: hidden;
}
.detail-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
}
.detail-cover-placeholder { font-size: 5rem; }
.detail-info { flex: 1; }
.detail-info h1 {
    font-size: 1.8rem;
    color: #2d1f14;
    margin-bottom: 0.3rem;
}
.detail-info .auteur {
    font-style: italic;
    color: #7a6652;
    margin-bottom: 1rem;
    font-size: 1rem;
}
.badge-reserve {
    display: inline-block;
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffc107;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.85rem;
    margin-bottom: 1.2rem;
}
.badge-disponible {
    display: inline-block;
    background: #d4edda;
    color: #155724;
    border: 1px solid #28a745;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.85rem;
    margin-bottom: 1.2rem;
}
.detail-description-title {
    font-weight: bold;
    color: #2d1f14;
    margin-bottom: 0.4rem;
    font-size: 1rem;
}
.detail-description {
    color: #4a3728;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
}
.detail-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}
.detail-actions form {
    margin: 0;
    padding: 0;
}
.btn-reserve {
    background: #5c3d2e;
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}
.btn-disabled {
    background: #ccc;
    color: #666;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    border: none;
    font-size: 0.95rem;
    cursor: not-allowed;
}
.link-back {
    color: #5c3d2e;
    text-decoration: none;
    font-size: 0.9rem;
}
</style>

<div class="detail-page">
    <div class="detail-card">

        <div class="detail-cover">
            {% if livre.image %}
                <img src="{{ asset('images/' ~ livre.image) }}" alt="{{ livre.titre }}">
            {% else %}
                <span class="detail-cover-placeholder">📖</span>
            {% endif %}
        </div>

        <div class="detail-info">
            <h1>{{ livre.titre }}</h1>
            <p class="auteur">Par {{ livre.auteur }}</p>

            {% if livre.exemplairesDisponibles > 0 %}
                <span class="badge-disponible">✅ Disponible</span>
            {% else %}
                <span class="badge-reserve">📚 Réservé pour le moment</span>
            {% endif %}

            <p class="detail-description-title">📖 Description :</p>
            <p class="detail-description">{{ livre.description }}</p>

            <div class="detail-actions">
                {% if livre.exemplairesDisponibles > 0 %}
                    <form method="post" action="{{ path('book_reserve', {id_livre: livre.idLivre}) }}">
                        <button type="submit" class="btn-reserve">📚 Réserver ce livre</button>
                    </form>
                {% else %}
                    <button class="btn-disabled" disabled>🔒 Déjà réservé pour le moment</button>
                {% endif %}

                <a href="{{ path('book_list') }}" class="link-back">← Choisir un autre livre</a>
            </div>
        </div>

    </div>
</div>
{% endblock %}