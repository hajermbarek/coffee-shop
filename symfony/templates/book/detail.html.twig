{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ livre.titre }}</h1>
<p><strong>Auteur :</strong> {{ livre.auteur }}</p>
<p><strong>Description :</strong> {{ livre.description }}</p>
<p><strong>Exemplaires disponibles :</strong> {{ livre.exemplairesDisponibles }}</p>

{% if livre.exemplairesDisponibles > 0 %}
    <form method="post" action="{{ path('book_reserve', {id_livre: livre.idLivre}) }}">
        <button type="submit">📚 Réserver ce livre</button>
    </form>
{% else %}
    <p>❌ Indisponible pour le moment</p>
{% endif %}

<a href="{{ path('book_list') }}">← Retour à la liste</a>
{% endblock %}
