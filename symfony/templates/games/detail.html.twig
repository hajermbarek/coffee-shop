{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
    <style>
        body { font-family: 'Manrope', sans-serif; background: #faf7f4; }

        .detail-wrap {
            max-width: 860px;
            margin: 48px auto 80px;
            padding: 0 24px;
        }
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #8b5e52;
            text-decoration: none;
            font-weight: 600;
            font-size: .9rem;
            margin-bottom: 28px;
            transition: color .2s;
        }
        .btn-back:hover { color: #3b2314; }

        .detail-card {
            background: #fff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 4px 32px rgba(0,0,0,.09);
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
        @media (max-width: 640px) {
            .detail-card { grid-template-columns: 1fr; }
        }

        .detail-img { width: 100%; height: 100%; min-height: 340px; object-fit: cover; }

        .detail-body { padding: 36px 32px; }

        .badge-cat {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 50px;
            font-size: .75rem;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 14px;
        }
        .detail-body h1 {
            font-size: 1.9rem;
            font-weight: 800;
            color: #2d1a0e;
            margin-bottom: 16px;
            line-height: 1.2;
        }
        .detail-meta {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .detail-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .9rem;
            color: #7a6655;
            background: #f5efe6;
            padding: 6px 14px;
            border-radius: 50px;
        }
        .detail-desc {
            font-size: .93rem;
            color: #6b5344;
            line-height: 1.7;
            margin-bottom: 24px;
            background: #faf7f4;
            padding: 16px;
            border-radius: 12px;
            border-left: 3px solid #d9822b;
        }
        .stock-info { font-size: .88rem; font-weight: 600; margin-bottom: 24px; }
        .stock-info.ok { color: #15803d; }
        .stock-info.ko { color: #b91c1c; }

        .detail-actions { display: flex; gap: 10px; }

        .btn-reserve {
            flex: 1;
            padding: 14px;
            background: #5c4033;
            color: #fff;
            border: none;
            border-radius: 12px;
            font-family: 'Manrope', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: background .2s;
        }
        .btn-reserve:hover { background: #3b2314; color: #fff; }
        .btn-reserve:disabled {
            background: #d4ccc5;
            color: #9e8070;
            cursor: not-allowed;
        }
        .btn-rules-detail {
            padding: 14px 20px;
            background: #f0ebe5;
            color: #5c4033;
            border: none;
            border-radius: 12px;
            font-family: 'Manrope', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: background .2s;
        }
        .btn-rules-detail:hover { background: #e0d8d0; color: #3b2314; }
    </style>
{% endblock %}

{% block body %}
<div class="detail-wrap">

    <a href="{{ path('games_list') }}" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i> Back to games
    </a>

    {% set colors = {'FUN':'#a0837f','STRATEGY':'#859fb9','CLASSIC GAME':'#d9822b'} %}

    <div class="detail-card">
      <img src="{{ asset('images' ~ game.imagePath) }}" alt="{{ game.name }}" class="detail-img"/>

        <div class="detail-body">
            <span class="badge-cat"
                  style="background: {{ colors[game.category] ?? '#8b5e52' }}">
                {{ game.category }}
            </span>

            <h1>{{ game.name }}</h1>

            <div class="detail-meta">
                <span>👥 {{ game.players }}</span>
                <span>⏳ {{ game.duration }}</span>
                <span>📦 {{ game.exemplairesTotal }} copies total</span>
            </div>

            <p class="detail-desc">{{ game.description }}</p>

            {% if game.exemplairesDisponibles > 0 %}
                <p class="stock-info ok">✅ {{ game.exemplairesDisponibles }} copy/copies available</p>
            {% else %}
                <p class="stock-info ko">❌ Currently unavailable</p>
            {% endif %}

            <div class="detail-actions">
                {% if game.exemplairesDisponibles > 0 %}
                    <a href="{{ path('app_reservation', {game: game.name, game_id: game.id}) }}"
                       class="btn-reserve">
                        🎲 Book this game
                    </a>
                {% else %}
                    <button class="btn-reserve" disabled>Unavailable</button>
                {% endif %}

                <button class="btn-rules-detail"
                        onclick="openRules({{ game.rules|json_encode|raw }}, '{{ game.name|replace({"'": "\\'"}) }}')">
                    📋 Rules
                </button>
            </div>
        </div>
    </div>
</div>

{# ── Modal Règles ── #}
<div id="rulesModal" onclick="closeOnBackdrop(event)"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5);
            z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:18px; padding:36px;
                max-width:520px; width:90%; max-height:80vh; overflow-y:auto;
                position:relative; box-shadow:0 20px 60px rgba(0,0,0,.2);">
        <span onclick="closeRules()"
              style="position:absolute; top:16px; right:20px; font-size:1.4rem;
                     cursor:pointer; color:#9e8070;">&times;</span>
        <h2 id="rulesTitle"
            style="font-family:'Manrope',sans-serif; color:#2d1a0e;
                   margin-bottom:16px; font-size:1.3rem; padding-right:24px;"></h2>
        <ul id="rulesText"
            style="font-family:'Manrope',sans-serif; color:#6b5344;
                   line-height:1.8; padding-left:20px; margin:0;"></ul>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/games.js') }}"></script>
{% endblock %}