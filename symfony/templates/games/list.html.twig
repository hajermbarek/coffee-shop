{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
    <style>
        body { font-family: 'Manrope', sans-serif; background: #faf7f4; }

        .games-hero {
            background: linear-gradient(135deg, #3b2314 0%, #6b3a2a 100%);
            color: #fff;
            padding: 56px 0 40px;
            text-align: center;
        }
        .games-hero h1 { font-size: 2.6rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 6px; }
        .games-hero p { opacity: .75; font-size: .95rem; }

        .search-section {
            background: #fff;
            border-bottom: 1px solid #ede8e3;
            padding: 20px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }
        .search-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            gap: 16px;
            align-items: center;
            flex-wrap: wrap;
        }
        .search-box { position: relative; flex: 1; min-width: 220px; }
        .search-box i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #a0837f; }
        .search-box input {
            width: 100%;
            padding: 11px 16px 11px 40px;
            border: 1.5px solid #e0d8d0;
            border-radius: 50px;
            font-family: 'Manrope', sans-serif;
            font-size: .92rem;
            background: #faf7f4;
            outline: none;
            transition: border .2s;
        }
        .search-box input:focus { border-color: #8b5e52; }

        .filter-buttons { display: flex; gap: 8px; flex-wrap: wrap; }
        .filter-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 18px;
            border-radius: 50px;
            font-size: .83rem;
            font-weight: 600;
            font-family: 'Manrope', sans-serif;
            text-decoration: none;
            border: 2px solid transparent;
            background: #f0ebe5;
            color: #5c4033;
            transition: all .2s;
        }
        .filter-btn:hover { background: #e8ddd5; color: #3b2314; }
        .filter-btn.active { background: #5c4033; color: #fff; border-color: #5c4033; }

        .results-bar { max-width: 1100px; margin: 28px auto 0; padding: 0 24px; font-size: .88rem; color: #8b7355; }
        .results-bar strong { color: #3b2314; }

        .games-grid {
            max-width: 1100px;
            margin: 20px auto 60px;
            padding: 0 24px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 28px;
        }

        .game-card {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 2px 16px rgba(0,0,0,.07);
            transition: transform .25s, box-shadow .25s;
            display: flex;
            flex-direction: column;
            position: relative;
        }
        .game-card:hover { transform: translateY(-6px); box-shadow: 0 12px 36px rgba(0,0,0,.13); }
        .game-card.unavailable { opacity: .65; }

        .card-img-wrap { width: 100%; height: 200px; overflow: hidden; position: relative; }
        .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
        .game-card:hover .card-img-wrap img { transform: scale(1.05); }

        .badge-category {
            position: absolute; top: 12px; left: 12px;
            padding: 4px 12px; border-radius: 50px;
            font-size: .72rem; font-weight: 700; color: #fff;
            text-transform: uppercase; letter-spacing: .5px;
        }
        .badge-stock {
            position: absolute; top: 12px; right: 12px;
            padding: 4px 10px; border-radius: 50px;
            font-size: .72rem; font-weight: 700; backdrop-filter: blur(6px);
        }
        .badge-stock.dispo { background: rgba(34,197,94,.15); color: #15803d; border: 1px solid #bbf7d0; }
        .badge-stock.indispo { background: rgba(239,68,68,.12); color: #b91c1c; border: 1px solid #fecaca; }

        .card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
        .card-body h3 { font-size: 1.1rem; font-weight: 700; color: #2d1a0e; margin-bottom: 8px; }
        .card-body .desc { font-size: .87rem; color: #7a6655; line-height: 1.55; flex: 1; margin-bottom: 14px; }
        .card-meta { display: flex; gap: 14px; font-size: .82rem; color: #9e8070; margin-bottom: 16px; }
        .card-meta span { display: flex; align-items: center; gap: 5px; }

        .card-actions { display: flex; gap: 10px; }
        .btn-book {
            flex: 1; padding: 10px; background: #5c4033; color: #fff;
            border: none; border-radius: 10px; font-family: 'Manrope', sans-serif;
            font-weight: 600; font-size: .88rem; text-align: center;
            text-decoration: none; cursor: pointer; transition: background .2s;
        }
        .btn-book:hover { background: #3b2314; color: #fff; }
        .btn-book:disabled, .btn-book.disabled { background: #d4ccc5; color: #9e8070; cursor: not-allowed; }
        .btn-rules {
            padding: 10px 16px; background: #f0ebe5; color: #5c4033;
            border: none; border-radius: 10px; font-family: 'Manrope', sans-serif;
            font-weight: 600; font-size: .88rem; cursor: pointer; transition: background .2s;
        }
        .btn-rules:hover { background: #e0d8d0; color: #3b2314; }

        .empty-state { grid-column: 1/-1; text-align: center; padding: 80px 20px; color: #9e8070; }
        .empty-state i { font-size: 3rem; margin-bottom: 16px; display: block; }
        .empty-state p { font-size: 1rem; margin-bottom: 20px; }
    </style>
{% endblock %}

{% block body %}

<div class="games-hero">
    <h1>🎲 Our Games</h1>
    <p>Find the perfect game for your visit</p>
</div>

<div class="search-section">
    <div class="search-inner">
        <form method="get" action="{{ path('games_list') }}" class="search-box" id="searchForm">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" id="searchInput"
                   placeholder="Search a game..."
                   value="{{ search }}"
                   autocomplete="off"/>
            {% if category != 'ALL' %}
                <input type="hidden" name="category" value="{{ category }}"/>
            {% endif %}
        </form>

        {% set icons  = {'ALL':'fa-table-cells','FUN':'fa-face-laugh-beam','STRATEGY':'fa-chess-knight','CLASSIC GAME':'fa-star'} %}
        {% set colors = {'ALL':'#5c4033','FUN':'#a0837f','STRATEGY':'#859fb9','CLASSIC GAME':'#d9822b'} %}

        <div class="filter-buttons">
            {% for cat in categories %}
                <a href="{{ path('games_list', {category: cat}) }}{% if search %}&search={{ search|url_encode }}{% endif %}"
                   class="filter-btn {{ category == cat ? 'active' : '' }}">
                    <i class="fa-solid {{ icons[cat] }}"></i> {{ cat }}
                </a>
            {% endfor %}
        </div>
    </div>
</div>

<div class="results-bar">
    <strong>{{ games|length }}</strong> game{{ games|length != 1 ? 's' : '' }} found
    {% if category != 'ALL' %} in <strong>{{ category }}</strong>{% endif %}
    {% if search %} for "<strong>{{ search }}</strong>"{% endif %}
</div>

{% set colors = {'ALL':'#5c4033','FUN':'#a0837f','STRATEGY':'#859fb9','CLASSIC GAME':'#d9822b'} %}
<div class="games-grid">
    {% for game in games %}
        <div class="game-card {{ game.exemplairesDisponibles == 0 ? 'unavailable' : '' }}">

            <div class="card-img-wrap">
                <img src="{{ asset('images/' ~ game.imagePath) }}" alt="{{ game.name }}" class="detail-img"/>
                <span class="badge-category"
                      style="background: {{ colors[game.category] ?? '#8b5e52' }}">
                    {{ game.category }}
                </span>
                <span class="badge-stock {{ game.exemplairesDisponibles > 0 ? 'dispo' : 'indispo' }}">
                    {{ game.exemplairesDisponibles > 0
                        ? '✅ ' ~ game.exemplairesDisponibles ~ ' available'
                        : '❌ Unavailable' }}
                </span>
            </div>

            <div class="card-body">
                <h3>{{ game.name }}</h3>
                <p class="desc">{{ game.description|slice(0, 110) }}…</p>
                <div class="card-meta">
                    <span>👥 {{ game.players }}</span>
                    <span>⏳ {{ game.duration }}</span>
                </div>
                <div class="card-actions">
                    {% if game.exemplairesDisponibles > 0 %}
                        <a href="#"
                           class="btn-book"
                           onclick="return checkStock({{ game.id }}, '{{ game.name|replace({"'": "\\'"}) }}', '{{ path('reservation_form', {game: game.name, game_id: game.id}) }}')">
                            Book
                        </a>
                    {% else %}
                        <button class="btn-book disabled" disabled>Unavailable</button>
                    {% endif %}
                    <button class="btn-rules"
                            onclick="openRules({{ game.rules|json_encode|raw }}, '{{ game.name|replace({"'": "\\'"}) }}')">
                        Rules
                    </button>
                </div>
            </div>

        </div>
    {% else %}
        <div class="empty-state">
            <i class="fa-solid fa-dice"></i>
            <p>No game found. Try another search or filter.</p>
            <a href="{{ path('games_list') }}" class="btn-book"
               style="display:inline-block;max-width:200px">See all games</a>
        </div>
    {% endfor %}
</div>

{# ── Modal Règles ── #}
<div id="rulesModal" onclick="closeOnBackdrop(event)"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5);
            z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:18px; padding:36px;
                max-width:520px; width:90%; max-height:80vh; overflow-y:auto;
                position:relative; box-shadow:0 20px 60px rgba(0,0,0,.2);">
        <span onclick="closeRules()"
              style="position:absolute; top:16px; right:20px; font-size:1.4rem;
                     cursor:pointer; color:#9e8070;">&times;</span>
        <h2 id="rulesTitle"
            style="font-family:'Manrope',sans-serif; color:#2d1a0e;
                   margin-bottom:16px; font-size:1.3rem; padding-right:24px;"></h2>
        <ul id="rulesText"
            style="font-family:'Manrope',sans-serif; color:#6b5344;
                   line-height:1.8; padding-left:20px; margin:0;"></ul>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/games.js') }}"></script>
{% endblock %}